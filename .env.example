# ----------------------------------------------------------------------------
# BunnyCal Web ‚Äî Environment variable reference
#
# Copy to `.env` (or `.env.local`) for local overrides. Vite also reads the
# committed `.env.development` / `.env.production` files automatically per mode,
# so you usually do not need a `.env` at all.
#
# IMPORTANT: every variable below is prefixed with VITE_, which means Vite
# inlines it into the browser bundle at build time. These values are PUBLIC.
# DO NOT put API keys, secrets, or credentials here ‚Äî anything secret belongs
# on the backend or in CI secrets, never in a VITE_* variable.
# ----------------------------------------------------------------------------

# --- API -------------------------------------------------------------------
# Origin of the BunnyCal backend API (no trailing slash).
#   development: http://localhost:8080
#   production:  https://api.bunnycal.io
VITE_API_BASE_URL=http://localhost:8080

# --- Debugging -------------------------------------------------------------
# Set to "true" to enable verbose auth/oauth/route console logging.
# Leave "false" (or unset) in production.
VITE_AUTH_DEBUG=false
