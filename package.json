{
  "name": "easyschedule-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test:e2e": "playwright test --project=google-host --project=public",
    "test:e2e:golden": "playwright test golden-path --project=google-host",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "capture:google-host": "tsx scripts/capture-auth-state.ts --persona=google-host",
    "capture:google-multi-calendar": "tsx scripts/capture-auth-state.ts --persona=google-multi-calendar",
    "capture:ms-personal": "tsx scripts/capture-auth-state.ts --persona=ms-personal",
    "capture:ms-work": "tsx scripts/capture-auth-state.ts --persona=ms-work",
    "capture:fresh-user": "tsx scripts/capture-auth-state.ts --persona=fresh-user"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
